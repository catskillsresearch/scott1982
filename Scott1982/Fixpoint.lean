import Scott1982.Theorem72
import Scott1982.Factoid33

/-!
# Least fixed-point operator — Theorem 7.3

**Scott 1982, Theorem 7.3.** Unique approximable `fix : (A → A) → A` such that
for every approximable `f : A → A`:
(ii) `f(fix(f)) ⊆ fix(f)` (in fact equality);
(iii) if `f(x) ⊆ x` then `fix(f) ⊆ x`.

`w (fix) v` means some `w`-chain from `∅` reaches a set that entails `v`.
-/

namespace Scott1982

open Scott1982.Constructive

namespace InfoSys

set_option linter.unusedSectionVars false

variable {α : Type*} [DecidableEq α] (A : InfoSys α)

/-- A length-`n` chain under the approximable map generated by `w`. -/
def FixChain (w : Finset (FunToken A A)) : Nat → Finset α → Prop
  | 0, v => v = ∅
  | n + 1, v =>
      ∃ u : Finset α, FixChain w n u ∧
        ∃ (hu : u ∈ A.Con) (hv : v ∈ A.Con),
          FunEnt A A w (mkFunToken A A u v hu hv)

/-- Reachability of `v` from `∅` by a finite `w`-chain. -/
def FixReach (w : Finset (FunToken A A)) (v : Finset α) : Prop :=
  ∃ n, FixChain A w n v

theorem fixChain_empty (w : Finset (FunToken A A)) : FixChain A w 0 ∅ :=
  rfl

theorem fixChain_con {w : Finset (FunToken A A)} {n : Nat} {v : Finset α}
    (h : FixChain A w n v) : v ∈ A.Con := by
  match n with
  | 0 =>
    rw [h]
    exact A.con_empty
  | n + 1 =>
    obtain ⟨_, _, _, hv, _⟩ := h
    exact hv

theorem fixReach_con {w : Finset (FunToken A A)} {v : Finset α}
    (h : FixReach A w v) : v ∈ A.Con := by
  obtain ⟨_, hn⟩ := h
  exact fixChain_con A hn

theorem fixReach_empty (w : Finset (FunToken A A)) : FixReach A w ∅ :=
  ⟨0, fixChain_empty A w⟩

theorem fixChain_pad_front {w : Finset (FunToken A A)} {n : Nat} {v : Finset α}
    (hw : FunCon A A w) (h : FixChain A w n v) : FixChain A w (n + 1) v := by
  induction n generalizing v with
  | zero =>
    rw [h]
    refine ⟨∅, rfl, A.con_empty, A.con_empty, ?_⟩
    exact (functionSystem A A).ent_bot hw
  | succ n ih =>
    obtain ⟨u, hu, huC, hvC, hEnt⟩ := h
    exact ⟨u, ih hu, huC, hvC, hEnt⟩

theorem fixChain_pad {w : Finset (FunToken A A)} {n k : Nat} {v : Finset α}
    (hw : FunCon A A w) (h : FixChain A w n v) : FixChain A w (n + k) v := by
  induction k with
  | zero => exact h
  | succ k ih => exact fixChain_pad_front A hw ih

theorem funEnt_union_step {w : Finset (FunToken A A)}
    {u u' v v' : Finset α}
    (hw : FunCon A A w) (hu : u ∈ A.Con) (hu' : u' ∈ A.Con)
    (hv : v ∈ A.Con) (hv' : v' ∈ A.Con)
    (hEnt : FunEnt A A w (mkFunToken A A u v hu hv))
    (hEnt' : FunEnt A A w (mkFunToken A A u' v' hu' hv'))
    (huU : u ∪' u' ∈ A.Con) :
    ∃ hvU : v ∪' v' ∈ A.Con,
      FunEnt A A w (mkFunToken A A (u ∪' u') (v ∪' v') huU hvU) := by
  obtain ⟨_, s1, hs1, hIn1, hOut1⟩ := hEnt
  obtain ⟨_, s2, hs2, hIn2, hOut2⟩ := hEnt'
  have hsub : s1 ∪' s2 ⊆ w := funion_subset_iff.mpr ⟨hs1, hs2⟩
  have hin : funInputUnion A A (s1 ∪' s2) ∈ A.Con := by
    rw [funInputUnion_funion]
    have hEntU : A.EntSet (u ∪' u')
        (funInputUnion A A s1 ∪' funInputUnion A A s2) :=
      proposition_2_3_vi A
        (proposition_2_3_v A hu huU (subset_funion_left _ _)
          (entSet_inputUnion_of_ent A A hIn1) (Finset.Subset.refl _))
        (proposition_2_3_v A hu' huU (subset_funion_right _ _)
          (entSet_inputUnion_of_ent A A hIn2) (Finset.Subset.refl _))
    exact A.con_subset (proposition_2_3_ii A huU hEntU) (subset_funion_right _ _)
  have hout : funOutputUnion A A s1 ∪' funOutputUnion A A s2 ∈ A.Con := by
    have := hw _ hsub hin
    rwa [funOutputUnion_funion] at this
  have hvU : v ∪' v' ∈ A.Con := by
    have hEntO : A.EntSet (funOutputUnion A A s1 ∪' funOutputUnion A A s2) (v ∪' v') :=
      proposition_2_3_vi A
        (proposition_2_3_v A
          (A.con_subset hout (subset_funion_left _ _)) hout
          (subset_funion_left _ _) hOut1 (Finset.Subset.refl _))
        (proposition_2_3_v A
          (A.con_subset hout (subset_funion_right _ _)) hout
          (subset_funion_right _ _) hOut2 (Finset.Subset.refl _))
    exact A.con_subset (proposition_2_3_ii A hout hEntO) (subset_funion_right _ _)
  refine ⟨hvU, hw, s1 ∪' s2, hsub, ?_, ?_⟩
  · intro q hq
    rcases mem_funion.mp hq with hq | hq
    · exact proposition_2_3_v A hu huU (subset_funion_left _ _) (hIn1 q hq)
        (Finset.Subset.refl _)
    · exact proposition_2_3_v A hu' huU (subset_funion_right _ _) (hIn2 q hq)
        (Finset.Subset.refl _)
  · rw [funOutputUnion_funion]
    exact proposition_2_3_vi A
      (proposition_2_3_v A
        (A.con_subset hout (subset_funion_left _ _)) hout
        (subset_funion_left _ _) hOut1 (Finset.Subset.refl _))
      (proposition_2_3_v A
        (A.con_subset hout (subset_funion_right _ _)) hout
        (subset_funion_right _ _) hOut2 (Finset.Subset.refl _))

theorem fixChain_union {w : Finset (FunToken A A)} {n : Nat} {v v' : Finset α}
    (hw : FunCon A A w) (h : FixChain A w n v) (h' : FixChain A w n v') :
    FixChain A w n (v ∪' v') := by
  induction n generalizing v v' with
  | zero =>
    rw [h, h']
    rfl
  | succ n ih =>
    obtain ⟨u, hu, huC, hvC, hEnt⟩ := h
    obtain ⟨u', hu', huC', hvC', hEnt'⟩ := h'
    have huU : u ∪' u' ∈ A.Con := fixChain_con A (ih hu hu')
    obtain ⟨hvU, hEntU⟩ := funEnt_union_step A hw huC huC' hvC hvC' hEnt hEnt' huU
    exact ⟨u ∪' u', ih hu hu', huU, hvU, hEntU⟩

theorem fixReach_union {w : Finset (FunToken A A)} {v v' : Finset α}
    (hw : FunCon A A w) (h : FixReach A w v) (h' : FixReach A w v') :
    FixReach A w (v ∪' v') := by
  obtain ⟨n, hn⟩ := h
  obtain ⟨m, hm⟩ := h'
  have hn' : FixChain A w (n + m) v := fixChain_pad A hw hn
  have hm' : FixChain A w (m + n) v' := fixChain_pad A hw hm
  have hm'' : FixChain A w (n + m) v' := by rwa [Nat.add_comm] at hm'
  exact ⟨n + m, fixChain_union A hw hn' hm''⟩

theorem fixChain_mono_w {w w' : Finset (FunToken A A)} {n : Nat} {v : Finset α}
    (hw : FunCon A A w) (hw' : FunCon A A w') (h : FixChain A w n v)
    (hEntw : (functionSystem A A).EntSet w' w) : FixChain A w' n v := by
  induction n generalizing v with
  | zero => exact h
  | succ n ih =>
    obtain ⟨u, hu, huC, hvC, hEnt⟩ := h
    refine ⟨u, ih hu, huC, hvC, ?_⟩
    exact (functionSystem A A).ent_trans hw' hw hEntw hEnt

theorem fixReach_mono_w {w w' : Finset (FunToken A A)} {v : Finset α}
    (hw : FunCon A A w) (hw' : FunCon A A w') (h : FixReach A w v)
    (hEntw : (functionSystem A A).EntSet w' w) : FixReach A w' v := by
  obtain ⟨n, hn⟩ := h
  exact ⟨n, fixChain_mono_w A hw hw' hn hEntw⟩

namespace ApproximableMap

/-- **Theorem 7.3.** Approximable least fixed-point operator. -/
def fixMap : ApproximableMap (functionSystem A A) A where
  rel w v :=
    w ∈ (functionSystem A A).Con ∧ v ∈ A.Con ∧
      ∃ v0, FixReach A w v0 ∧ A.EntSet v0 v
  rel_dom h := h.1
  rel_cod h := h.2.1
  empty_rel :=
    ⟨(functionSystem A A).con_empty, A.con_empty, ∅, fixReach_empty A _, A.entSet_empty ∅⟩
  union_right := by
    rintro w v v' ⟨hw, hv, v0, hv0, hEnt0⟩ ⟨_, hv', v0', hv0', hEnt0'⟩
    have hv0C := fixReach_con A hv0
    have hv0'C := fixReach_con A hv0'
    have hUreach : FixReach A w (v0 ∪' v0') := fixReach_union A hw hv0 hv0'
    have hv0U := fixReach_con A hUreach
    have hEntU : A.EntSet (v0 ∪' v0') (v ∪' v') :=
      proposition_2_3_vi A
        (proposition_2_3_v A hv0C hv0U (subset_funion_left _ _) hEnt0 (Finset.Subset.refl _))
        (proposition_2_3_v A hv0'C hv0U (subset_funion_right _ _) hEnt0' (Finset.Subset.refl _))
    refine ⟨hw, ?_, v0 ∪' v0', hUreach, hEntU⟩
    exact A.con_subset (proposition_2_3_ii A hv0U hEntU) (subset_funion_right _ _)
  mono := by
    rintro w w' v v' ⟨hw, hv, v0, hv0, hEnt0⟩ hEntw hEntv hw' hv'
    refine ⟨hw', hv', v0, fixReach_mono_w A hw hw' hv0 hEntw, ?_⟩
    exact proposition_2_3_iv A (fixReach_con A hv0) hv hEnt0 hEntv

/-- Least fixed point of an approximable endomap, as an element. -/
def fixElement (f : ApproximableMap A A) : A.Element :=
  (fixMap A).toElement (approxMap_toElement A A f)

/-- Tokens of `w ⊆ approxMap_toElement f` satisfy `f.rel`. -/
private theorem rel_of_mem_approx (f : ApproximableMap A A)
    {w : Finset (FunToken A A)}
    (hw : ↑w ⊆ (approxMap_toElement A A f).carrier) {p : FunToken A A}
    (hp : p ∈ w) : f.rel p.val.1 p.val.2 := by
  simpa [mem_approxMap_toElement] using hw (Finset.mem_coe.2 hp)

/-- A `w`-chain under tokens from `f` stays inside a pre-fixed point. -/
theorem fixChain_subset_pre_fixed (f : ApproximableMap A A) (x : A.Element)
    (hpre : f.toElement x ≤ x) {w : Finset (FunToken A A)}
    (hw : ↑w ⊆ (approxMap_toElement A A f).carrier) {n : Nat} {u : Finset α}
    (h : FixChain A w n u) : ↑u ⊆ x.carrier := by
  induction n generalizing u with
  | zero =>
    intro b hb
    rw [h] at hb
    exact False.elim (Finset.notMem_empty b hb)
  | succ n ih =>
    obtain ⟨u0, hu0, hu0C, huC, hEnt⟩ := h
    have hu0_sub := ih hu0
    obtain ⟨_, s, hs, hIn, hOut⟩ := hEnt
    have hps : ∀ q ∈ s, f.rel q.val.1 q.val.2 := fun q hq =>
      rel_of_mem_approx A f hw (hs hq)
    have hin : funInputUnion A A s ∈ A.Con :=
      A.con_subset
        (proposition_2_3_ii A hu0C (entSet_inputUnion_of_ent A A hIn))
        (subset_funion_right _ _)
    have hrel : f.rel (funInputUnion A A s) (funOutputUnion A A s) :=
      rel_input_output_union A A f s hps hin
    have hrel' : f.rel u0 (funOutputUnion A A s) :=
      f.mono hrel (entSet_inputUnion_of_ent A A hIn)
        (proposition_2_3_iii A (f.rel_cod hrel)) hu0C (f.rel_cod hrel)
    have hrel'' : f.rel u0 u :=
      f.mono hrel' (proposition_2_3_iii A hu0C) hOut hu0C huC
    intro b hb
    have hsing : f.rel u0 {b} :=
      f.mono hrel'' (proposition_2_3_iii A hu0C)
        (fun z hz => by
          rw [Finset.mem_singleton] at hz; subst hz
          exact A.ent_refl huC hb)
        hu0C (A.con_sing b)
    exact hpre ⟨u0, hu0_sub, hsing⟩

/-- **Theorem 7.3(iii).** `fix(f)` is below every pre-fixed point. -/
theorem fixElement_le_of_pre_fixed (f : ApproximableMap A A) (x : A.Element)
    (hpre : f.toElement x ≤ x) : fixElement A f ≤ x := by
  intro a ⟨w, hw, ⟨hwCon, haCon, v0, hv0, hEnt⟩⟩
  obtain ⟨n, hn⟩ := hv0
  have hsub := fixChain_subset_pre_fixed A f x hpre hw hn
  have hEnta : A.Ent v0 a := hEnt a (Finset.mem_singleton_self _)
  exact x.closed v0 a hsub hEnta

/-- Extend a chain by one `f`-step using a token from `approxMap_toElement f`. -/
theorem fixChain_step_of_rel (f : ApproximableMap A A)
    {w : Finset (FunToken A A)} {n : Nat} {u v : Finset α}
    (hw : ↑w ⊆ (approxMap_toElement A A f).carrier)
    (hu : FixChain A w n u) (hrel : f.rel u v) :
    ∃ w' : Finset (FunToken A A),
      ↑w' ⊆ (approxMap_toElement A A f).carrier ∧
        FunCon A A w' ∧ FixChain A w' (n + 1) v := by
  let p := mkFunToken A A u v (f.rel_dom hrel) (f.rel_cod hrel)
  have hp : p ∈ (approxMap_toElement A A f).carrier := by
    simpa [p, mem_approxMap_toElement, mkFunToken] using hrel
  let w' := insert p w
  have hw' : ↑w' ⊆ (approxMap_toElement A A f).carrier := by
    intro q hq
    rcases Finset.mem_insert.mp (Finset.mem_coe.1 hq) with rfl | hq
    · exact hp
    · exact hw (Finset.mem_coe.2 hq)
  have hw'Con : FunCon A A w' :=
    (approxMap_toElement A A f).consistent w' hw'
  have hwCon : FunCon A A w :=
    (approxMap_toElement A A f).consistent w hw
  have hu' : FixChain A w' n u :=
    fixChain_mono_w A hwCon hw'Con hu
      (fun q hq => (functionSystem A A).ent_refl hw'Con (Finset.mem_insert_of_mem hq))
  refine ⟨w', hw', hw'Con, u, hu', f.rel_dom hrel, f.rel_cod hrel, ?_⟩
  refine ⟨hw'Con, {p}, ?_, ?_, ?_⟩
  · intro q hq
    cases Finset.mem_singleton.mp hq
    exact Finset.mem_insert_self _ _
  · intro q hq
    cases Finset.mem_singleton.mp hq
    exact proposition_2_3_iii A (f.rel_dom hrel)
  · rw [funOutputUnion_singleton]
    exact proposition_2_3_iii A (f.rel_cod hrel)

/-- **Theorem 7.3(ii).** `f(fix(f)) ⊆ fix(f)`. -/
theorem toElement_fixElement_le (f : ApproximableMap A A) :
    f.toElement (fixElement A f) ≤ fixElement A f := by
  intro a ⟨u, hu, hrel⟩
  obtain ⟨w, hw, ⟨hwCon, _, v0, hv0, hEnt⟩⟩ :=
    exists_rel_of_subset_image (fixMap A) (approxMap_toElement A A f) u hu
  -- v0 entails u, and f.rel u {a}; mono to get f.rel v0 {a} after adjusting
  have hv0C := fixReach_con A hv0
  have huC : u ∈ A.Con := f.rel_dom hrel
  have hrel' : f.rel v0 {a} :=
    f.mono hrel hEnt
      (proposition_2_3_iii A (f.rel_cod hrel)) hv0C (f.rel_cod hrel)
  obtain ⟨n, hn⟩ := hv0
  obtain ⟨w', hw', hw'Con, hchain⟩ := fixChain_step_of_rel A f hw hn hrel'
  refine ⟨w', hw', ⟨hw'Con, A.con_sing a, {a}, ⟨n + 1, hchain⟩, ?_⟩⟩
  exact proposition_2_3_iii A (A.con_sing a)

/-- **Theorem 7.3.** `fix(f)` is a fixed point. -/
theorem fixElement_fixed (f : ApproximableMap A A) :
    f.toElement (fixElement A f) = fixElement A f := by
  apply le_antisymm
  · exact toElement_fixElement_le A f
  · have hpre : f.toElement (f.toElement (fixElement A f)) ≤
        f.toElement (fixElement A f) :=
      toElement_mono f (toElement_fixElement_le A f)
    exact fixElement_le_of_pre_fixed A f (f.toElement (fixElement A f)) hpre

/-- **Theorem 7.3.** Uniqueness of the least fixed-point operator on elements. -/
theorem fixElement_unique (f : ApproximableMap A A) (φ : A.Element)
    (hfix : f.toElement φ ≤ φ)
    (hleast : ∀ x : A.Element, f.toElement x ≤ x → φ ≤ x) :
    φ = fixElement A f := by
  apply le_antisymm
  · exact hleast _ (toElement_fixElement_le A f)
  · exact fixElement_le_of_pre_fixed A f φ hfix

/-- Uniqueness of `fix` as an approximable operator (Scott Thm 7.3). -/
theorem fixMap_unique (φ : ApproximableMap (functionSystem A A) A)
    (hpre : ∀ f : ApproximableMap A A,
      f.toElement (φ.toElement (approxMap_toElement A A f)) ≤
        φ.toElement (approxMap_toElement A A f))
    (hleast : ∀ f : ApproximableMap A A, ∀ x : A.Element,
      f.toElement x ≤ x → φ.toElement (approxMap_toElement A A f) ≤ x) :
    φ = fixMap A :=
  (ext_iff_toElement φ (fixMap A)).2 fun g => by
    let hf := element_toApproxMap A A g
    have hg : approxMap_toElement A A hf = g :=
      approxMap_toElement_element_toApproxMap A A g
    rw [← hg]
    exact fixElement_unique A hf (φ.toElement (approxMap_toElement A A hf))
      (hpre hf) (hleast hf)

end ApproximableMap

end InfoSys

end Scott1982
